    editor = vim
[alias]
	p = push
	last = log -1 HEAD
    unstage = restore --staged . 
    confige = config --global -e
    ls = log --oneline
    alias = config --global -e
    url = git remote get-url --all origin
    cd = checkout
    changed =diff --shortstat
    pop =stash pop
[core]
    pager = delta
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true
    line-numbers = true
    side-by-side = true
#   syntax-theme = GitHub
[merge]
    conflictstyle = diff3
[diff]
    colorMoved = default
